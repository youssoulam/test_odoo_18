<?xml version="1.0" encoding="utf-8" ?>
<odoo>

    <!-- Vue liste du modèle livre -->
    <record id="gestion_bibliotheque_livre_view_list" model="ir.ui.view">
    <field name="name">gestion.bibliotheque.livre.view.list</field>
    <field name="model">gestion.bibliotheque.livre</field>
    <field name="arch" type="xml">
        <list>
            <field name="name" />
            <field name="isbn" />
            <field name="maison_edition" />
            <field name="annee_publication" />
            <field name="auteur_id" />
        </list>
    </field>
    </record>

    <!-- Vue formulaire du modèle livre -->
    <record id="gestion_bibliotheque_livre_view_form" model="ir.ui.view">
    <field name="name">gestion.bibliotheque.livre.view.form</field>
    <field name="model">gestion.bibliotheque.livre</field>
    <field name="arch" type="xml">
        <form>
            <sheet>
                <group>
                    <group>
                        <field name="name" />
                        <field name="isbn" />
                        <field name="maison_edition" />
                    </group>
                    <group>
                        <field name="annee_publication" />
                        <field name="auteur_id" />
                    </group>
                </group>
            </sheet>
        </form>
    </field>
    </record>

    <!-- l'action du menu livre -->
    <record model="ir.actions.act_window" id="action_gestion_bibliotheque_livre">
        <field name="name">Livres</field>
        <field name="res_model">gestion.bibliotheque.livre</field>
        <field name="view_mode">list,form</field>
        <field name="view_id" ref="gestion_bibliotheque_livre_view_list"/>
    </record>

</odoo>
